# ── Agent / extraction LLM ──────────────────────────────────────────────────
LLM_PROVIDER=deepseek       # preset name — see table below
LLM_API_KEY=                # optional: overrides the preset's key env var
LLM_BASE_URL=               # optional: custom OpenAI-compatible base URL
LLM_MODEL=                  # optional: overrides the preset's default model

# ── Per-provider API keys (set whichever matches LLM_PROVIDER) ───────────────
DEEPSEEK_API_KEY=           # platform.deepseek.com      → preset: deepseek
OPENAI_API_KEY=             # platform.openai.com        → preset: openai
ANTHROPIC_API_KEY=          # console.anthropic.com      → preset: anthropic
GEMINI_API_KEY=             # aistudio.google.com        → preset: gemini
GROQ_API_KEY=               # console.groq.com           → preset: groq
MISTRAL_API_KEY=            # console.mistral.ai         → preset: mistral
XAI_API_KEY=                # console.x.ai               → preset: xai
TOGETHER_API_KEY=           # api.together.xyz           → preset: together
# Ollama runs locally — no API key required                preset: ollama

# ── Web search (optional) ────────────────────────────────────────────────────
TAVILY_API_KEY=             # tavily.com (free tier: 1 000 credits/month)
                            # omit to use DuckDuckGo + BeautifulSoup fallback
